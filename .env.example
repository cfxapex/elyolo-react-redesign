### Supabase (Admin + CMS)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

### Shopify (Shop page + Shopify checkout)
# Example store domain: your-store.myshopify.com (NO https://)
VITE_SHOPIFY_STORE_DOMAIN=
VITE_SHOPIFY_STOREFRONT_TOKEN=
# Optional (defaults to 2024-10)
VITE_SHOPIFY_API_VERSION=2024-10

### Admin allowlist (recommended)
# Comma-separated emails that are allowed into /admin/*
# Example: admin@elyolo.com,owner@elyolo.com
VITE_ADMIN_EMAILS=

